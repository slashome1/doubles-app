<%- include('partials/header') %>
<section class="hero card sticky-summary">
  <div>
    <div class="eyebrow">Round #<%= round.id %> · <%= round.status %></div>
    <div class="money">ACE Pot <%= currency(acePot) %></div>
    <% if (round.status !== 'signup') { %><p class="muted">Includes this round’s ace contributions.</p><% } %>
    <% if (round.ctp_hole) { %><div class="pill ctp-pill">CTP Hole: <strong><%= round.ctp_hole %></strong></div><% } %>
  </div>
  <div class="totals-grid">
    <div><span>Greens</span><strong><%= currency(round.greens_total) %></strong></div>
    <div><span>CTP</span><strong><%= currency(round.ctp_total) %></strong></div>
    <div><span>Payout</span><strong><%= currency(round.payout_total) %></strong></div>
  </div>
</section>

<% const activePlayers = players.filter(p => !p.dropped); %>
<% const showPlayersTab = players.length > 0; %>
<% const currentView = view || (round.status === 'signup' ? 'signup' : 'teams'); %>

<% if (showPlayersTab || round.status !== 'signup') { %>
<section class="card">
  <div class="tab-row">
    <% if (round.status === 'signup') { %>
      <a class="button <%= currentView === 'signup' ? 'primary' : 'secondary' %> tab-button" href="/rounds/<%= round.id %>?view=signup">Signup</a>
    <% } %>
    <a class="button <%= currentView === 'players' ? 'primary' : 'secondary' %> tab-button" href="/rounds/<%= round.id %>?view=players">Players</a>
    <% if (round.status !== 'signup') { %>
      <a class="button <%= currentView === 'teams' ? 'primary' : 'secondary' %> tab-button" href="/rounds/<%= round.id %>?view=teams">Round</a>
    <% } %>
  </div>
</section>
<% } %>

<section class="grid two">
  <% if (round.status === 'signup' && currentView !== 'players') { %>
  <section class="card">
    <h2>Signup</h2>
    <form method="get" action="/rounds/<%= round.id %>" class="stack small">
      <label>Search existing players
        <input name="player_query" value="<%= playerQuery || '' %>" placeholder="Start typing a name" />
      </label>
      <button class="button ghost big-touch" type="submit">Filter Player List</button>
    </form>
    <form method="post" action="/rounds/<%= round.id %>/players" class="stack">
      <label>Add existing player
        <select name="player_id" class="big-touch">
          <option value="">Pick previous player</option>
          <% allPlayers.forEach((player) => { %>
            <option value="<%= player.id %>"><%= player.name %> <%= player.is_member ? '(member)' : '(guest)' %></option>
          <% }) %>
        </select>
      </label>
      <label class="inline touch-option"><input type="radio" name="player_mode" value="existing" checked /> Use existing</label>
      <label class="inline touch-option"><input type="radio" name="player_mode" value="new" /> Create new</label>
      <label>New player name
        <input name="new_player_name" placeholder="Only needed for brand new players" />
      </label>
      <label class="inline touch-option"><input type="checkbox" name="is_member" /> Club member</label>
      <div class="checkbox-grid">
        <label class="inline touch-option"><input type="checkbox" name="ctp_paid" checked /> CTP $1</label>
        <label class="inline touch-option"><input type="checkbox" name="ace_paid" checked /> Ace $1</label>
        <label class="inline touch-option"><input type="checkbox" name="payout_paid" checked /> Payout $5</label>
      </div>
      <button class="button primary large" type="submit">Add Player</button>
    </form>
  </section>
  <% } %>

  <% if (currentView === 'players') { %>
  <section class="card">
    <h2>Players in Round</h2>
    <% if (!players.length) { %><p class="muted">Nobody signed up yet.</p><% } %>
    <div class="stack small">
      <% players.forEach((player) => { %>
        <div class="player-card">
          <form method="post" action="/round-players/<%= player.id %>/update" class="stack">
            <input type="hidden" name="round_id" value="<%= round.id %>" />
            <div class="player-head"><strong><%= player.name %></strong><span><%= player.dropped ? 'Dropped / Forfeit kept' : (player.is_member ? 'Member' : 'Guest') %></span></div>
            <div class="checkbox-grid compact">
              <label class="inline touch-option"><input type="checkbox" name="is_member" <%= player.is_member ? 'checked' : '' %> /> Member</label>
              <label class="inline touch-option"><input type="checkbox" name="ctp_paid" <%= player.ctp_paid ? 'checked' : '' %> /> CTP</label>
              <label class="inline touch-option"><input type="checkbox" name="ace_paid" <%= player.ace_paid ? 'checked' : '' %> /> Ace</label>
              <label class="inline touch-option"><input type="checkbox" name="payout_paid" <%= player.payout_paid ? 'checked' : '' %> /> Payout</label>
            </div>
            <label>Greens fee
              <input type="number" name="greens_fee" min="0" step="0.01" value="<%= player.greens_fee %>" />
            </label>
            <div class="actions-row">
              <button class="button secondary big-touch" type="submit">Save</button>
            </div>
          </form>
          <div class="actions-row">
            <form method="post" action="/round-players/<%= player.id %>/drop-toggle" onsubmit="return confirm('<%= player.dropped ? 'Restore this player to active status?' : 'Drop this player? Their money will stay in the round as a forfeit.' %>')">
              <button class="button <%= player.dropped ? 'secondary' : 'danger' %> big-touch" type="submit"><%= player.dropped ? 'Restore Player' : 'Drop Player' %></button>
            </form>
            <% if (currentUser.role === 'admin') { %>
              <form method="post" action="/round-players/<%= player.id %>/delete" onsubmit="return confirm('Remove this player from the round?')">
                <button class="button danger big-touch" type="submit">Remove</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
  <% } %>
</section>

<% if (round.status === 'signup') { %>
<section class="card">
  <h2>Start Round</h2>
  <p class="muted">Randomly pick a CTP hole from admin-approved holes: <%= eligibleHoles.join(', ') || 'none yet' %></p>
  <form method="post" action="/rounds/<%= round.id %>/start">
    <button class="button primary large" type="submit" <%= players.length < 2 ? 'disabled' : '' %>>Start the Round!</button>
  </form>
</section>
<% } %>

<% if (round.status === 'ready' || round.status === 'teams') { %>
<section class="grid two">
  <% if (!teams.length && currentView !== 'players') { %>
  <section class="card">
    <h2>Randomize Teams</h2>
    <p>Current players: <strong><%= activePlayers.length %></strong></p>
    <p>CTP payout: <strong><%= currency(round.ctp_total) %></strong></p>
    <p>Winning payout: <strong><%= currency(round.payout_total) %></strong></p>
    <form method="post" action="/rounds/<%= round.id %>/randomize">
      <button class="button primary large" type="submit">Randomize Teams</button>
    </form>
  </section>
  <% } %>

  <% if (currentView !== 'players') { %>
  <section class="card">
    <h2>Teams</h2>
    <% if (!teams.length) { %>
      <p class="muted">No teams yet.</p>
    <% } else { %>
      <div class="stack small">
        <% teams.forEach((team) => { %>
          <div class="team-card">
            <div class="player-head"><strong><%= team.team_name %></strong><span><%= team.is_cali ? 'Cali' : 'Pair' %></span></div>
            <div><%= team.player_names %></div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <% if (currentUser.role === 'admin') { %>
      <hr />
      <form method="post" action="/rounds/<%= round.id %>/manual-teams" class="stack">
        <label>Manual teams (one team per line, comma separated names)
          <textarea name="teams" rows="5" placeholder="Alice, Bob&#10;Chris"></textarea>
        </label>
        <button class="button secondary big-touch" type="submit">Apply Manual Teams</button>
      </form>
    <% } %>
  </section>
  <% } %>
</section>
<% } %>

<% if (round.status === 'teams' && currentView !== 'players') { %>
<section class="card">
  <h2>Finish Round</h2>
  <p class="muted">When the round is done, tap below to record ace / CTP / winner payouts.</p>
  <button class="button primary large" type="button" onclick="document.getElementById('complete-round-panel').hidden = false; this.hidden = true;">Complete Round</button>
</section>

<section class="card" id="complete-round-panel" hidden>
  <h2>Round Results</h2>
  <form method="post" action="/rounds/<%= round.id %>/complete" class="stack">
    <label>Ace result
      <select name="ace_result" id="ace_result" class="big-touch" required>
        <option value="no">No ace</option>
        <option value="yes">Ace hit</option>
      </select>
    </label>

    <div id="ace_hitters_group" hidden>
      <label>Ace player(s)</label>
      <div class="stack small">
        <% activePlayers.forEach((player) => { %>
          <label class="inline touch-option selector-card"><input type="checkbox" name="ace_player_ids" value="<%= player.player_id %>" /> <span><%= player.name %></span></label>
        <% }) %>
      </div>
    </div>

    <label>Who got CTP? (Payout <%= currency(round.ctp_total) %>)
      <select name="ctp_player_id" class="big-touch">
        <option value="">No CTP winner</option>
        <% activePlayers.forEach((player) => { %>
          <option value="<%= player.player_id %>"><%= player.name %></option>
        <% }) %>
      </select>
    </label>
    <label>Winning team (Payout <%= currency(round.payout_total) %>)
      <select name="winner_team_id" class="big-touch">
        <option value="">No winner selected</option>
        <% teams.forEach((team) => { %>
          <option value="<%= team.id %>"><%= team.team_name %> — <%= team.player_names %></option>
        <% }) %>
      </select>
    </label>
    <button class="button primary large" type="submit">Save Round Results</button>
  </form>
</section>

<script>
  (() => {
    const aceResult = document.getElementById('ace_result');
    const aceGroup = document.getElementById('ace_hitters_group');
    if (!aceResult || !aceGroup) return;
    const syncAce = () => {
      const show = aceResult.value === 'yes';
      aceGroup.hidden = !show;
      aceGroup.querySelectorAll('input[type="checkbox"]').forEach((el) => {
        if (!show) el.checked = false;
      });
    };
    aceResult.addEventListener('change', syncAce);
    syncAce();
  })();
</script>
<% } %>

<% if (currentUser.role === 'admin' && round.status !== 'completed') { %>
<section class="card">
  <h2>Admin Controls</h2>
  <div class="grid two">
    <form method="post" action="/rounds/<%= round.id %>/set-ctp-hole" class="stack">
      <label>Set / correct CTP hole
        <select name="ctp_hole" class="big-touch" required>
          <option value="">Pick hole</option>
          <% eligibleHoles.forEach((hole) => { %>
            <option value="<%= hole %>" <%= String(round.ctp_hole) === String(hole) ? 'selected' : '' %>><%= hole %></option>
          <% }) %>
        </select>
      </label>
      <button class="button secondary big-touch" type="submit">Save CTP Hole</button>
    </form>

    <form method="post" action="/rounds/<%= round.id %>/reset-teams" class="stack" onsubmit="return confirm('Clear current teams and move the round back to ready state?')">
      <div>
        <strong>Reset teams</strong>
        <p class="muted">Use this if pairings need to be redone after edits or dropouts.</p>
      </div>
      <button class="button secondary big-touch" type="submit">Clear Teams / Rebuild</button>
    </form>
  </div>

  <form method="post" action="/rounds/<%= round.id %>/cancel" onsubmit="return confirm('Cancel and delete this unfinished round?')">
    <button class="button danger large" type="submit">Cancel Current Round</button>
  </form>
</section>
<% } %>
<%- include('partials/footer') %>
