<%- include('partials/header') %>
<section class="card">
  <h2>Admin Settings</h2>
  <form method="post" action="<%= path('/admin/settings') %>" class="stack">
    <label>Eligible CTP holes (comma separated)
      <input name="holes" value="<%= holes.join(', ') %>" placeholder="3, 7, 12, 17" />
    </label>
    <label>Current ACE pot
      <input name="ace_pot" type="number" min="0" step="0.01" value="<%= acePot %>" />
    </label>
    <button class="button primary" type="submit">Save Settings</button>
  </form>
</section>

<section class="card">
  <h2>Login PINs</h2>
  <form method="post" action="<%= path('/admin/users/pins') %>" class="stack">
    <label>Admin PIN
      <input name="admin_pin" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="0815" required />
    </label>
    <label>User PIN
      <input name="user_pin" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="9020" required />
    </label>
    <button class="button primary" type="submit">Update PINs</button>
  </form>
  <p class="muted">Database: <code><%= dbPath %></code></p>
</section>

<section class="card">
  <h2>Admin Audit Log</h2>
  <% if (!auditLog.length) { %>
    <p class="muted">No admin actions recorded yet.</p>
  <% } else { %>
    <div class="stack small">
      <% auditLog.forEach((item) => { %>
        <div class="team-card">
          <div class="player-head"><strong><%= item.action %></strong><span><%= item.created_at %></span></div>
          <div>Actor: <strong><%= item.actor_username || 'system' %></strong></div>
          <% if (item.round_id) { %><div>Round: <strong>#<%= item.round_id %></strong></div><% } %>
          <% if (item.detail) { %><div><%= item.detail %></div><% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
<%- include('partials/footer') %>
