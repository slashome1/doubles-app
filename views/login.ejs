<%- include('partials/header') %>
<div class="page-banner">
  <img src="<%= path('/olympus-banner.jpg') %>" alt="Olympus banner" style="max-width:100%; height:auto; border-radius:8px; display:block; margin:0 auto 1rem;" />
</div>
<section class="card narrow">
  <h2>PIN Login</h2>
  <p class="muted">Quick entry for league night. Default accounts are documented in the README.</p>
  <form method="post" action="<%= path('/login') %>" class="stack">
    <label>Username
      <input name="username" list="users" placeholder="admin or user" required />
    </label>
    <datalist id="users">
      <% users.forEach((user) => { %><option value="<%= user.username %>"></option><% }) %>
    </datalist>
    <label>PIN
      <input name="pin" inputmode="numeric" pattern="[0-9]*" maxlength="8" required />
    </label>
    <button class="button primary" type="submit">Enter App</button>
  </form>
</section>
<%- include('partials/footer') %>
