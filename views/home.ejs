<%- include('partials/header') %>
<section class="hero card">
  <div>
    <div class="eyebrow">Current ACE Pot</div>
    <div class="money"><%= currency(acePot) %></div>
  </div>
  <form method="post" action="/rounds">
    <button class="button primary large" type="submit">Start New Doubles Round</button>
  </form>
</section>
<section class="card">
  <h2>Recent Completed Rounds</h2>
  <% if (!recentRounds.length) { %>
    <p class="muted">No completed rounds yet.</p>
  <% } else { %>
    <div class="stack small">
      <% recentRounds.forEach((round) => { %>
        <div class="team-card">
          <div class="player-head"><strong>Round #<%= round.id %></strong><span><%= round.completed_at || round.created_at %></span></div>
          <div>CTP hole: <strong><%= round.ctp_hole || '—' %></strong></div>
          <div>ACE payout: <strong><%= currency(round.ace_payout_total) %></strong> · CTP: <strong><%= currency(round.ctp_payout_total) %></strong> · Winners: <strong><%= currency(round.winner_payout_total) %></strong></div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
<%- include('partials/footer') %>
