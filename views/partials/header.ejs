<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Olympus Doubles</title>
  <link rel="stylesheet" href="<%= path('/styles.css') %>" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand-block">
        <div class="brand-art">
          <img src="<%= path('/olympus-banner.jpg') %>" alt="Olympus Disc Golf Course banner" />
        </div>
        <div class="brand-copy">
          <div class="eyebrow">Olympus Disc Golf Course</div>
          <h1>Olympus Doubles</h1>
          <p>League-night round tracking, payouts, and ace pot management.</p>
        </div>
      </div>
      <% if (currentUser) { %>
        <div class="topbar-actions">
          <a class="button secondary" href="<%= path('/') %>">Home</a>
          <a class="button secondary" href="<%= path('/rounds/history') %>">History</a>
          <span class="pill"><%= currentUser.username %> · <%= currentUser.role %></span>
          <% if (currentUser.role === 'admin') { %>
            <a class="button secondary" href="<%= path('/admin/settings') %>">Settings</a>
            <a class="button secondary" href="<%= path('/admin/stats') %>">Stats</a>
          <% } %>
          <form method="post" action="<%= path('/logout') %>"><button class="button ghost" type="submit">Log out</button></form>
        </div>
      <% } %>
    </div>
  </header>
  <% if (flash) { %><div class="flash"><%= flash %></div><% } %>
  <main class="container">
