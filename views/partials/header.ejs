<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Olympus Doubles</title>
  <link rel="stylesheet" href="<%= path('/styles.css') %>" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-actions">
        <a class="button secondary" href="<%= path('/') %>">Home</a>
        <a class="button secondary" href="<%= path('/rounds/history') %>">History</a>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <a class="button secondary" href="<%= path('/admin/settings') %>">Settings</a>
          <a class="button secondary" href="<%= path('/admin/stats') %>">Stats</a>
        <% } %>
        <form method="post" action="<%= path('/logout') %>" style="display:inline"><button class="button ghost" type="submit">Log out</button></form>
      </div>
    </div>
  </header>
  <% if (flash) { %><div class="flash"><%= flash %></div><% } %>
  <main class="container">
    <div class="page-banner">
      <img src="<%= path('/olympus-banner.jpg') %>" alt="Olympus banner" style="max-width:100%; height:auto; border-radius:8px; display:block; margin:0 auto 1rem;" />
    </div>
