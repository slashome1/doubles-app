  </main>

  <div class="page-back" aria-hidden="false" style="text-align:center; margin:1rem 0 2rem;">
    <button class="button secondary" onclick="history.back()">Back</button>
  </div>

<script>
(function(){
  const topbar = document.querySelector('.topbar');
  const main = document.querySelector('main');
  if (!topbar || !main) return;
  // expose topbar height for layout
  function setTopbarHeight(){
    const h = topbar.getBoundingClientRect().height;
    document.documentElement.style.setProperty('--topbar-height', h + 'px');
    main.classList.add('main-with-topbar');
  }
  setTopbarHeight();
  window.addEventListener('resize', setTopbarHeight);

  // start visible
  topbar.classList.add('showing');

  let last = window.scrollY || 0;
  let ticking = false;
  let hidden = false;
  const threshold = 28; // larger threshold to avoid jitter
  let lock = false; // brief lock to prevent snap
  const lockDuration = 320; // ms

  function onScroll(){
    const st = window.scrollY || 0;
    const delta = st - last;
    if (!ticking){
      window.requestAnimationFrame(() => {
        if (lock) { last = st <= 0 ? 0 : st; ticking = false; return; }
        if (delta > threshold && st > 20){
          if (!hidden){ topbar.classList.add('hidden'); topbar.classList.remove('showing'); hidden = true; lock = true; last = st + threshold; setTimeout(()=>{ lock=false; setTopbarHeight(); }, lockDuration); }
        } else if (delta < -threshold){
          if (hidden){ topbar.classList.remove('hidden'); topbar.classList.add('showing'); hidden = false; lock = true; last = st - threshold; setTimeout(()=>{ lock=false; setTopbarHeight(); }, lockDuration); }
        }
        last = st <= 0 ? 0 : st;
        ticking = false;
      });
      ticking = true;
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  // reveal zone: if header hidden, allow small top strip to capture wheel/mouseenter to re-open it
  const reveal = document.querySelector('.topbar-reveal');
  if (reveal){
    reveal.addEventListener('wheel', (ev)=>{
      if (ev.deltaY < 0 && hidden){ // wheel up
        topbar.classList.remove('hidden'); topbar.classList.add('showing'); hidden = false; setTopbarHeight();
      }
    }, { passive: true });
    reveal.addEventListener('mouseenter', ()=>{
      if (hidden){ topbar.classList.remove('hidden'); topbar.classList.add('showing'); hidden = false; setTopbarHeight(); }
    });
  }
})();
</script>

</body>
</html>
</script>

</body>
</html>
